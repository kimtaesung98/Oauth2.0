# =============================================================================
# OAuth2.0 Project — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 환경 변수 & 시크릿 (Secrets & Credentials)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template

*.pem
*.key
*.p12
*.pfx
*.jks
*.crt
*.cer
*.der

client_secret*.json
credentials.json
service-account*.json
*-service-account.json
token.json
tokens.json
oauth_token*
refresh_token*
access_token*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.venv/
venv/
ENV/
env/
.virtualenv/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*

# -----------------------------------------------------------------------------
# Java / Spring
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.log
.mvn/
hs_err_pid*

# -----------------------------------------------------------------------------
# IDE & 에디터
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 로그 & 임시 파일
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.cache

# -----------------------------------------------------------------------------
# 데이터베이스
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# 테스트 커버리지
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
coverage/
